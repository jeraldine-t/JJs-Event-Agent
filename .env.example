# Runtime
TIMEZONE=Asia/Singapore
EVENT_KEYWORDS=AI,Data,Tech,Robotics,Product,Design,Marketing,Business,Networking
LOOKAHEAD_DAYS=90
MESSAGE_LOOKBACK_DAYS=14
PLAYWRIGHT_HEADLESS=true
# WhatsApp is opt-in because it requires a persistent self-hosted browser profile.
ENABLED_SOURCES=linkedin,eventbrite,luma,meetup,gdg
OUTPUT_HTML=index.html
SOURCE_FAILURE_MODE=warn

# LinkedIn. Prefer the single li_at value; alternatively provide a Playwright cookie JSON array.
LINKEDIN_LI_AT=
LINKEDIN_COOKIES_JSON=
LINKEDIN_MAX_PROFILES=30
LINKEDIN_POSTS_PER_PROFILE=12

# Eventbrite. A full cookie array preserves the eventbrite.com/.sg domains.
EVENTBRITE_COOKIES_JSON=
EVENTBRITE_MAX_EVENTS=80

# Meetup. Public source; no credentials required.
MEETUP_MAX_EVENTS=60

# Google Developer Groups. Public source; no credentials required.
GDG_MAX_EVENTS=60

# Lu.ma. Cookie JSON is a Playwright-compatible array. Add private/unlisted URLs explicitly.
LUMA_COOKIES_JSON=
LUMA_DISCOVERY_URLS=
LUMA_PRIVATE_URLS=
LUMA_MAX_EVENTS=80

# WhatsApp Web persistent profile. Use an absolute path on a self-hosted Actions runner.
WHATSAPP_USER_DATA_DIR=.state/whatsapp
WHATSAPP_GROUPS=
WHATSAPP_MESSAGES_PER_GROUP=100

# Optional scraper overrides (pipe-separated URLs).
EVENTBRITE_SEARCH_URLS=
MEETUP_SEARCH_URLS=
HTTP_TIMEOUT_SECONDS=30

# Weekly email summary. Keep EMAIL_ENABLED=false for ordinary local runs.
# Use credentials from a mail provider that supports app-specific SMTP authentication.
EMAIL_ENABLED=false
EMAIL_RECIPIENT=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
