<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="A calendar of curated AI, tech, robotics, marketing, business, and networking events in Singapore with admission confidence and F&amp;B status.">
  <title>JJs Event Agent · Singapore</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07110f;
      --surface: rgba(16, 35, 30, .86);
      --surface-2: rgba(23, 47, 40, .84);
      --line: rgba(180, 229, 210, .15);
      --text: #f3f9f6;
      --muted: #9eb6ad;
      --lime: #c1f875;
      --mint: #68e9bd;
      --peach: #ffb78f;
      --blue: #9fc5ff;
      --amber: #f3d38a;
      --shadow: 0 24px 70px rgba(0, 0, 0, .25);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      background:
        radial-gradient(circle at 12% 2%, rgba(65, 215, 166, .17), transparent 32rem),
        radial-gradient(circle at 88% 22%, rgba(193, 248, 117, .09), transparent 30rem),
        var(--bg);
      font: 15px/1.55 Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    a { color: inherit; }
    .shell { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 54px 0 80px; }
    header { display: grid; grid-template-columns: 1fr auto; gap: 30px; align-items: end; }
    .eyebrow { color: var(--mint); text-transform: uppercase; letter-spacing: .16em; font-size: 12px; font-weight: 850; }
    h1 { margin: 7px 0 10px; max-width: 820px; font-size: clamp(40px, 7vw, 78px); line-height: .96; letter-spacing: -.055em; }
    .intro { max-width: 760px; margin: 0; color: var(--muted); font-size: 17px; }
    .count {
      min-width: 156px; padding: 20px; border: 1px solid var(--line); border-radius: 24px;
      background: var(--surface); box-shadow: var(--shadow); text-align: center; backdrop-filter: blur(16px);
    }
    .count strong { display: block; color: var(--lime); font-size: 44px; line-height: 1; }
    .count span { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .12em; }
    .breakdowns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 28px 0 22px; }
    .stat { padding: 16px 18px; border: 1px solid var(--line); border-radius: 18px; background: rgba(15, 32, 28, .68); }
    .stat strong { display: block; margin-bottom: 3px; font-size: 24px; color: var(--text); }
    .stat span { color: var(--muted); font-size: 12px; }
    .stat.fnb strong { color: var(--peach); }
    .stat.price-unknown strong { color: var(--amber); }
    .toolbar {
      display: grid; grid-template-columns: minmax(220px, 1fr) repeat(3, 180px); gap: 10px;
      position: sticky; top: 12px; z-index: 5; margin: 0 0 34px; padding: 10px;
      border: 1px solid var(--line); border-radius: 20px; background: rgba(8, 19, 16, .88); backdrop-filter: blur(20px);
    }
    .search, .select {
      width: 100%; height: 46px; border: 1px solid var(--line); border-radius: 13px;
      background: rgba(18, 38, 32, .92); color: var(--text); padding: 0 14px; outline: none;
    }
    .search:focus, .select:focus { border-color: var(--mint); box-shadow: 0 0 0 3px rgba(104, 233, 189, .11); }
    .calendar-month { margin-top: 40px; }
    .month-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 16px; }
    .month-heading h2 { margin: 0; font-size: clamp(27px, 4vw, 42px); letter-spacing: -.035em; }
    .month-heading span { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .09em; }
    .calendar-day {
      display: grid; grid-template-columns: 104px minmax(0, 1fr); gap: 18px;
      padding: 18px 0; border-top: 1px solid var(--line);
    }
    .day-rail { padding: 6px 0 0; }
    .day-rail strong { display: block; color: var(--lime); font-size: 42px; line-height: .95; letter-spacing: -.05em; }
    .day-rail span { color: var(--muted); font-size: 12px; }
    .day-events { display: grid; gap: 14px; }
    .event-card {
      display: grid; grid-template-columns: minmax(0, 1fr) 230px; gap: 22px; padding: 22px;
      border: 1px solid var(--line); border-radius: 23px; background: var(--surface);
      box-shadow: var(--shadow); transition: transform .18s ease, border-color .18s ease;
    }
    .event-card:hover { transform: translateY(-2px); border-color: rgba(193, 248, 117, .38); }
    .event-card.featured { background: linear-gradient(145deg, rgba(29, 60, 49, .96), rgba(13, 29, 25, .91)); }
    .topline { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .source { color: var(--mint); font-size: 11px; font-weight: 850; letter-spacing: .1em; text-transform: uppercase; }
    .pill { border-radius: 999px; padding: 4px 8px; font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .04em; }
    .free { color: #07110f; background: var(--lime); }
    .price-unknown { color: var(--amber); border: 1px solid rgba(243, 211, 138, .3); background: rgba(243, 211, 138, .08); }
    .window { color: var(--blue); border: 1px solid rgba(159, 197, 255, .25); background: rgba(159, 197, 255, .07); }
    .event-card h3 { margin: 15px 0 9px; font-size: clamp(21px, 3vw, 29px); line-height: 1.12; letter-spacing: -.025em; }
    .summary { max-width: 760px; margin: 0; color: #c5d7d0; }
    .tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 16px; }
    .tag { padding: 5px 9px; border: 1px solid var(--line); border-radius: 999px; color: #cce5dc; background: rgba(104, 233, 189, .055); font-size: 11px; }
    .tag.perk { color: var(--peach); border-color: rgba(255, 183, 143, .26); background: rgba(255, 183, 143, .065); }
    .event-side { display: flex; flex-direction: column; gap: 13px; padding-left: 20px; border-left: 1px solid var(--line); }
    .meta { display: grid; gap: 6px; color: var(--muted); font-size: 13px; }
    .meta b { color: var(--text); }
    .fnb-status { padding: 12px; border-radius: 14px; border: 1px solid var(--line); background: rgba(255,255,255,.025); }
    .fnb-status span { display: block; margin-bottom: 3px; color: var(--muted); font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .1em; }
    .fnb-status strong { color: var(--peach); font-size: 13px; }
    .fnb-status.none strong { color: var(--muted); }
    .register { margin-top: auto; display: flex; justify-content: space-between; align-items: center; gap: 12px; text-decoration: none; font-weight: 850; }
    .register span:last-child { color: var(--lime); font-size: 22px; }
    .empty, .status-panel { padding: 28px; border: 1px solid var(--line); border-radius: 22px; background: var(--surface); }
    .empty h2 { margin: 0 0 7px; }
    .status-panel { margin-top: 40px; }
    .status-panel summary { cursor: pointer; font-weight: 850; }
    .statuses { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin-top: 18px; }
    .status { padding: 13px; border-radius: 14px; background: rgba(255,255,255,.035); }
    .state-ok { color: var(--mint); } .state-skipped { color: #f3d38a; } .state-failed { color: #ff9e9e; }
    footer { margin-top: 24px; color: var(--muted); font-size: 12px; }
    [hidden] { display: none !important; }
    @media (max-width: 880px) {
      .breakdowns { grid-template-columns: repeat(2, 1fr); }
      .toolbar { grid-template-columns: 1fr 1fr; }
      .search { grid-column: 1 / -1; }
      .event-card { grid-template-columns: 1fr; }
      .event-side { padding: 16px 0 0; border-left: 0; border-top: 1px solid var(--line); }
    }
    @media (max-width: 620px) {
      .shell { width: min(100% - 22px, 1180px); padding-top: 32px; }
      header { grid-template-columns: 1fr; align-items: start; }
      .count { width: 100%; display: flex; justify-content: center; gap: 10px; align-items: baseline; }
      .toolbar { grid-template-columns: 1fr; }
      .search { grid-column: auto; }
      .calendar-day { grid-template-columns: 1fr; gap: 9px; }
      .day-rail { display: flex; align-items: baseline; gap: 10px; }
      .day-rail strong { font-size: 31px; }
      .event-card { padding: 18px; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header>
      <div>
        <div class="eyebrow">Singapore · Curated event intel</div>
        <h1>Your social calendar, curated.</h1>
        <p class="intro">AI, tech, robotics, marketing, business and networking events—organized by date, with admission confidence and food or drink clearly called out.</p>
      </div>
      <div class="count"><strong id="visible-count">{{ events|length }}</strong><span>events showing</span></div>
    </header>

    <section class="breakdowns" aria-label="Event breakdowns">
      <div class="stat"><strong>{{ breakdowns.free_confirmed }}</strong><span>confirmed free</span></div>
      <div class="stat price-unknown"><strong>{{ breakdowns.price_unconfirmed }}</strong><span>price not stated</span></div>
      <div class="stat fnb"><strong>{{ breakdowns.fnb }}</strong><span>with explicit F&amp;B</span></div>
      <div class="stat"><strong>{{ breakdowns.weekday }}</strong><span>weekday evenings</span></div>
      <div class="stat"><strong>{{ breakdowns.weekend }}</strong><span>weekend daytime</span></div>
      <div class="stat"><strong>{{ breakdowns.networking }}</strong><span>mention networking</span></div>
    </section>

    <div class="toolbar" aria-label="Event filters">
      <input class="search" id="search" type="search" placeholder="Search events, summaries, places or perks…" aria-label="Search events">
      <select class="select" id="source" aria-label="Filter by source">
        <option value="">All sources</option>
        {% for source in source_names %}<option value="{{ source|lower }}">{{ source }}</option>{% endfor %}
      </select>
      <select class="select" id="fnb" aria-label="Filter by food and beverage">
        <option value="">Any F&amp;B status</option>
        <option value="yes">F&amp;B mentioned</option>
        <option value="no">F&amp;B not stated</option>
      </select>
      <select class="select" id="price" aria-label="Filter by admission confidence">
        <option value="">Any admission status</option>
        <option value="confirmed">Confirmed free</option>
        <option value="unconfirmed">Price not stated</option>
      </select>
    </div>

    <section id="events" aria-live="polite" aria-label="Event calendar">
      {% for month in calendar_months %}
      <section class="calendar-month" data-month="{{ month.month_key }}">
        <div class="month-heading"><h2>{{ month.month_label }}</h2><span>{{ month.event_count }} event{% if month.event_count != 1 %}s{% endif %}</span></div>
        {% for day in month.days %}
        <section class="calendar-day" data-date="{{ day.date_key }}" aria-label="{{ day.date_label }}">
          <div class="day-rail"><strong>{{ day.day_number }}</strong><span>{{ day.weekday }}</span></div>
          <div class="day-events">
            {% for event in day.events %}
            <article class="event-card{% if event.has_fnb or 'Networking' in event.perks %} featured{% endif %}" data-search="{{ (event.title ~ ' ' ~ event.summary ~ ' ' ~ event.location ~ ' ' ~ event.source ~ ' ' ~ event.admission_label ~ ' ' ~ event.perks|join(' ') ~ ' ' ~ event.keywords|join(' '))|lower }}" data-source="{{ event.source|lower }}" data-fnb="{{ 'yes' if event.has_fnb else 'no' }}" data-price="{{ 'confirmed' if event.free_confirmed else 'unconfirmed' }}">
              <div class="event-main">
                <div class="topline"><span class="source">{{ event.source }}</span><span class="pill {{ 'free' if event.free_confirmed else 'price-unknown' }}">{{ event.admission_label }}</span><span class="pill window">{{ event.day_type }}</span></div>
                <h3>{{ event.title }}</h3>
                <p class="summary">{{ event.summary }}</p>
                <div class="tags">
                  {% for perk in event.perks %}<span class="tag perk">{{ perk }}</span>{% endfor %}
                  {% for keyword in event.keywords %}<span class="tag">{{ keyword }}</span>{% endfor %}
                </div>
              </div>
              <aside class="event-side">
                <div class="meta">
                  <span><b>When</b><br>{{ event.date_label }}<br>{{ event.time_label }}</span>
                  <span><b>Where</b><br>{{ event.location }}</span>
                </div>
                <div class="fnb-status{% if not event.has_fnb %} none{% endif %}"><span>Food &amp; beverage</span><strong>{{ event.fnb_label }}</strong></div>
                <a class="register" href="{{ event.url }}" target="_blank" rel="noopener noreferrer"><span>Registration &amp; details</span><span>↗</span></a>
              </aside>
            </article>
            {% endfor %}
          </div>
        </section>
        {% endfor %}
      </section>
      {% endfor %}
      <div class="empty" id="empty"{% if events %} hidden{% endif %}>
        <h2>No matches yet.</h2>
        <p>{% if events %}Try a broader search or reset the source, admission, and F&amp;B filters.{% else %}The latest run found no events that met the topic, location, date, and timing filters. Check back after the next Sunday refresh.{% endif %}</p>
      </div>
    </section>

    <details class="status-panel">
      <summary>Run health · generated {{ generated_at }}</summary>
      <div class="statuses">
        {% for status in statuses %}
        <div class="status"><b>{{ status.source }}</b><br><span class="state-{{ status.state }}">{{ status.state }}</span>{% if status.found %} · {{ status.found }} candidates{% endif %}</div>
        {% endfor %}
      </div>
      <p><small>Accepted {{ report.accepted }}. Rejections: {% for reason, count in report.rejected.items() %}{{ reason }}={{ count }}{% if not loop.last %}, {% endif %}{% else %}none{% endfor %}.</small></p>
    </details>
    <footer>Times shown in Singapore Time (SGT). “Price not stated” means no admission price was found; it does not guarantee free entry. Events with an explicit paid price are excluded. F&amp;B means the source explicitly mentions food or drinks.</footer>
  </main>
  <script>
    const search = document.querySelector('#search');
    const source = document.querySelector('#source');
    const fnb = document.querySelector('#fnb');
    const price = document.querySelector('#price');
    const cards = [...document.querySelectorAll('.event-card')];
    const days = [...document.querySelectorAll('.calendar-day')];
    const months = [...document.querySelectorAll('.calendar-month')];
    const count = document.querySelector('#visible-count');
    const empty = document.querySelector('#empty');
    function filterCards() {
      const query = search.value.trim().toLowerCase();
      const selectedSource = source.value;
      const selectedFnb = fnb.value;
      const selectedPrice = price.value;
      let visible = 0;
      cards.forEach(card => {
        const show = (!query || card.dataset.search.includes(query))
          && (!selectedSource || card.dataset.source === selectedSource)
          && (!selectedFnb || card.dataset.fnb === selectedFnb)
          && (!selectedPrice || card.dataset.price === selectedPrice);
        card.hidden = !show;
        if (show) visible += 1;
      });
      days.forEach(day => {
        day.hidden = ![...day.querySelectorAll('.event-card')].some(card => !card.hidden);
      });
      months.forEach(month => {
        month.hidden = ![...month.querySelectorAll('.calendar-day')].some(day => !day.hidden);
      });
      count.textContent = visible;
      empty.hidden = visible !== 0;
    }
    search.addEventListener('input', filterCards);
    source.addEventListener('change', filterCards);
    fnb.addEventListener('change', filterCards);
    price.addEventListener('change', filterCards);
  </script>
</body>
</html>
