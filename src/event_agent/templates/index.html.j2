<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="A date-first calendar of curated AI, tech, robotics, marketing, business, and networking events in Singapore.">
  <title>JJs Event Agent · Singapore</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07110f;
      --surface: rgba(16, 35, 30, .88);
      --surface-2: rgba(23, 47, 40, .84);
      --line: rgba(180, 229, 210, .15);
      --line-strong: rgba(180, 229, 210, .27);
      --text: #f3f9f6;
      --muted: #9eb6ad;
      --lime: #c1f875;
      --mint: #68e9bd;
      --peach: #ffb78f;
      --blue: #9fc5ff;
      --amber: #f3d38a;
      --shadow: 0 24px 70px rgba(0, 0, 0, .25);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      background:
        radial-gradient(circle at 12% 2%, rgba(65, 215, 166, .15), transparent 32rem),
        radial-gradient(circle at 88% 22%, rgba(193, 248, 117, .08), transparent 30rem),
        var(--bg);
      font: 15px/1.55 Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    a { color: inherit; }
    button, input, select { font: inherit; }
    .shell { width: min(1280px, calc(100% - 32px)); margin: 0 auto; padding: 28px 0 80px; }
    .app-header { display: flex; align-items: center; justify-content: space-between; gap: 22px; margin-bottom: 18px; }
    .brand { display: flex; align-items: center; gap: 13px; }
    .brand-mark {
      display: grid; width: 42px; height: 42px; place-items: center; border-radius: 13px;
      color: #102018; background: var(--lime); font-weight: 950; letter-spacing: -.04em;
      box-shadow: 0 10px 34px rgba(193, 248, 117, .15);
    }
    .eyebrow { color: var(--mint); text-transform: uppercase; letter-spacing: .15em; font-size: 10px; font-weight: 850; }
    .brand h1 { margin: 1px 0 0; font-size: clamp(19px, 2.8vw, 27px); line-height: 1.1; letter-spacing: -.035em; }
    .count { display: flex; align-items: baseline; gap: 8px; color: var(--muted); font-size: 12px; }
    .count strong { color: var(--lime); font-size: 26px; line-height: 1; }
    .calendar-overview {
      overflow: hidden; border: 1px solid var(--line-strong); border-radius: 26px;
      background: rgba(10, 24, 20, .9); box-shadow: var(--shadow); backdrop-filter: blur(18px);
    }
    .calendar-heading {
      display: flex; align-items: end; justify-content: space-between; gap: 24px;
      padding: 24px 26px 20px; border-bottom: 1px solid var(--line);
    }
    .calendar-heading h2 { margin: 3px 0 2px; font-size: clamp(29px, 4vw, 44px); line-height: 1; letter-spacing: -.045em; }
    .calendar-heading p { margin: 8px 0 0; color: var(--muted); font-size: 13px; }
    .month-nav { display: flex; align-items: center; gap: 8px; }
    .nav-button {
      display: grid; width: 42px; height: 42px; place-items: center; border: 1px solid var(--line-strong);
      border-radius: 13px; color: var(--text); background: var(--surface); cursor: pointer;
      transition: border-color .18s ease, transform .18s ease, opacity .18s ease;
    }
    .nav-button:hover:not(:disabled) { transform: translateY(-1px); border-color: var(--mint); }
    .nav-button:disabled { cursor: default; opacity: .28; }
    .month-scroll { overflow-x: auto; scrollbar-color: rgba(104, 233, 189, .25) transparent; }
    .calendar-canvas { min-width: 840px; }
    .weekday-row, .month-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); }
    .weekday-row { border-bottom: 1px solid var(--line); background: rgba(255, 255, 255, .018); }
    .weekday-row span { padding: 10px 12px; color: var(--muted); font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .11em; }
    .month-panel { min-height: 560px; }
    .month-cell {
      min-height: 112px; padding: 9px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line);
      background: rgba(255, 255, 255, .006); transition: background .18s ease;
    }
    .month-cell:nth-child(7n) { border-right: 0; }
    .month-cell.outside { color: rgba(158, 182, 173, .38); background: rgba(0, 0, 0, .07); }
    .month-cell.has-events { background: rgba(104, 233, 189, .025); }
    .month-cell.is-today { box-shadow: inset 0 0 0 1px var(--mint); }
    .day-number {
      display: grid; width: 27px; height: 27px; place-items: center; margin-bottom: 5px;
      border-radius: 9px; color: var(--muted); font-size: 12px; font-weight: 800;
    }
    .is-today .day-number { color: #102018; background: var(--mint); }
    .calendar-event {
      display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 6px; align-items: start;
      margin-top: 5px; padding: 6px 7px; border: 1px solid rgba(104, 233, 189, .14);
      border-radius: 9px; color: #dff8ef; background: rgba(104, 233, 189, .075);
      text-decoration: none; font-size: 10px; line-height: 1.25;
    }
    .calendar-event:hover { border-color: rgba(193, 248, 117, .45); background: rgba(193, 248, 117, .1); }
    .calendar-event time { color: var(--lime); font-weight: 850; white-space: nowrap; }
    .calendar-event span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .calendar-footer {
      display: flex; align-items: center; justify-content: space-between; gap: 18px;
      padding: 13px 22px; color: var(--muted); border-top: 1px solid var(--line); font-size: 11px;
    }
    .calendar-footer strong { color: var(--text); }
    .toolbar {
      display: grid; grid-template-columns: minmax(220px, 1fr) 220px 220px; gap: 10px;
      position: sticky; top: 12px; z-index: 5; margin: 22px 0 38px; padding: 10px;
      border: 1px solid var(--line); border-radius: 20px; background: rgba(8, 19, 16, .9); backdrop-filter: blur(20px);
    }
    .search, .select {
      width: 100%; height: 46px; border: 1px solid var(--line); border-radius: 13px;
      background: rgba(18, 38, 32, .96); color: var(--text); padding: 0 14px; outline: none;
    }
    .search:focus, .select:focus { border-color: var(--mint); box-shadow: 0 0 0 3px rgba(104, 233, 189, .11); }
    .agenda-heading { display: flex; justify-content: space-between; gap: 20px; align-items: end; margin-bottom: 8px; }
    .agenda-heading h2 { margin: 0; font-size: clamp(27px, 4vw, 42px); letter-spacing: -.04em; }
    .agenda-heading p { margin: 0; max-width: 520px; color: var(--muted); text-align: right; font-size: 12px; }
    .agenda-month { margin-top: 40px; }
    .month-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 16px; }
    .month-heading h3 { margin: 0; font-size: clamp(23px, 3vw, 34px); letter-spacing: -.035em; }
    .month-heading span { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .09em; }
    .calendar-day {
      display: grid; grid-template-columns: 104px minmax(0, 1fr); gap: 18px;
      padding: 18px 0; border-top: 1px solid var(--line);
    }
    .day-rail { padding: 6px 0 0; }
    .day-rail strong { display: block; color: var(--lime); font-size: 42px; line-height: .95; letter-spacing: -.05em; }
    .day-rail span { color: var(--muted); font-size: 12px; }
    .day-events { display: grid; gap: 14px; }
    .event-card {
      scroll-margin-top: 90px; display: grid; grid-template-columns: minmax(0, 1fr) 230px; gap: 22px; padding: 22px;
      border: 1px solid var(--line); border-radius: 23px; background: var(--surface);
      box-shadow: var(--shadow); transition: transform .18s ease, border-color .18s ease;
    }
    .event-card:hover { transform: translateY(-2px); border-color: rgba(193, 248, 117, .38); }
    .event-card.featured { background: linear-gradient(145deg, rgba(29, 60, 49, .96), rgba(13, 29, 25, .91)); }
    .topline { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .source { color: var(--mint); font-size: 11px; font-weight: 850; letter-spacing: .1em; text-transform: uppercase; }
    .pill { border-radius: 999px; padding: 4px 8px; font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .04em; }
    .hot { color: #1b1200; background: var(--amber); }
    .window { color: var(--blue); border: 1px solid rgba(159, 197, 255, .25); background: rgba(159, 197, 255, .07); }
    .event-card h4 { margin: 15px 0 9px; font-size: clamp(21px, 3vw, 29px); line-height: 1.12; letter-spacing: -.025em; }
    .summary { max-width: 760px; margin: 0; color: #c5d7d0; }
    .summary.missing { color: var(--muted); font-style: italic; }
    .tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 16px; }
    .tag { padding: 5px 9px; border: 1px solid var(--line); border-radius: 999px; color: #cce5dc; background: rgba(104, 233, 189, .055); font-size: 11px; }
    .tag.perk { color: var(--peach); border-color: rgba(255, 183, 143, .26); background: rgba(255, 183, 143, .065); }
    .event-side { display: flex; flex-direction: column; gap: 13px; padding-left: 20px; border-left: 1px solid var(--line); }
    .meta { display: grid; gap: 6px; color: var(--muted); font-size: 13px; }
    .meta b { color: var(--text); }
    .fnb-status { padding: 12px; border-radius: 14px; border: 1px solid var(--line); background: rgba(255,255,255,.025); }
    .fnb-status span, .popularity span { display: block; margin-bottom: 3px; color: var(--muted); font-size: 10px; font-weight: 850; text-transform: uppercase; letter-spacing: .1em; }
    .fnb-status strong { color: var(--peach); font-size: 13px; }
    .fnb-status.none strong { color: var(--muted); }
    .popularity { padding: 12px; border-radius: 14px; border: 1px solid rgba(243, 211, 138, .22); background: rgba(243, 211, 138, .055); }
    .popularity strong { color: var(--amber); font-size: 13px; }
    .register { margin-top: auto; display: flex; justify-content: space-between; align-items: center; gap: 12px; text-decoration: none; font-weight: 850; }
    .register span:last-child { color: var(--lime); font-size: 22px; }
    .empty, .status-panel { padding: 28px; border: 1px solid var(--line); border-radius: 22px; background: var(--surface); }
    .empty h2 { margin: 0 0 7px; }
    .status-panel { margin-top: 40px; }
    .status-panel summary { cursor: pointer; font-weight: 850; }
    .statuses { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin-top: 18px; }
    .status { padding: 13px; border-radius: 14px; background: rgba(255,255,255,.035); }
    .state-ok { color: var(--mint); } .state-skipped { color: #f3d38a; } .state-failed { color: #ff9e9e; }
    footer { margin-top: 24px; color: var(--muted); font-size: 12px; }
    .presentation-mode .source, .presentation-mode #source { display: none; }
    .presentation-mode .toolbar { grid-template-columns: minmax(220px, 1fr) 220px; }
    [hidden] { display: none !important; }
    @media (max-width: 880px) {
      .toolbar { grid-template-columns: 1fr 1fr; }
      .search { grid-column: 1 / -1; }
      .event-card { grid-template-columns: 1fr; }
      .event-side { padding: 16px 0 0; border-left: 0; border-top: 1px solid var(--line); }
    }
    @media (max-width: 620px) {
      .shell { width: min(100% - 22px, 1280px); padding-top: 18px; }
      .app-header { align-items: flex-start; }
      .brand-mark { width: 38px; height: 38px; }
      .count { flex-direction: column; gap: 0; align-items: end; }
      .calendar-heading { align-items: center; padding: 19px 18px 16px; }
      .calendar-heading p { display: none; }
      .calendar-canvas { min-width: 700px; }
      .month-cell { min-height: 98px; padding: 7px; }
      .calendar-footer { align-items: flex-start; }
      .calendar-footer span:first-child { max-width: 210px; }
      .toolbar { grid-template-columns: 1fr; }
      .presentation-mode .toolbar { grid-template-columns: 1fr; }
      .search { grid-column: auto; }
      .agenda-heading { align-items: start; flex-direction: column; }
      .agenda-heading p { text-align: left; }
      .calendar-day { grid-template-columns: 1fr; gap: 9px; }
      .day-rail { display: flex; align-items: baseline; gap: 10px; }
      .day-rail strong { font-size: 31px; }
      .event-card { padding: 18px; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="app-header">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true">JJ</div>
        <div><div class="eyebrow">Singapore · Curated event intel</div><h1>JJs Event Agent</h1></div>
      </div>
      <div class="count"><strong id="visible-count">{{ events|length }}</strong><span>events showing</span></div>
    </header>

    <section class="calendar-overview" aria-label="Monthly event calendar">
      <div class="calendar-heading">
        <div>
          <div class="eyebrow">Plan by date</div>
          <h2 id="active-month-label">{{ calendar_overview[0].month_label }}</h2>
          <p>See your month at a glance, then jump directly to any event’s details.</p>
        </div>
        <nav class="month-nav" aria-label="Calendar month navigation">
          <button class="nav-button" id="previous-month" type="button" aria-label="Previous month">←</button>
          <button class="nav-button" id="next-month" type="button" aria-label="Next month">→</button>
        </nav>
      </div>
      <div class="month-scroll">
        <div class="calendar-canvas">
          <div class="weekday-row" aria-hidden="true"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>
          {% for month in calendar_overview %}
          <section class="month-panel" data-month-index="{{ loop.index0 }}" data-month-label="{{ month.month_label }}"{% if not loop.first %} hidden{% endif %} aria-label="{{ month.month_label }}">
            <div class="month-grid" role="grid">
              {% for week in month.weeks %}
                {% for cell in week %}
                <div class="month-cell{% if not cell.in_month %} outside{% endif %}{% if cell.events %} has-events{% endif %}{% if cell.is_today %} is-today{% endif %}" data-date="{{ cell.date_iso }}" role="gridcell" aria-label="{{ cell.date_label }}">
                  <time class="day-number" datetime="{{ cell.date_iso }}">{{ cell.day_number }}</time>
                  {% for event in cell.events %}
                  <a class="calendar-event" href="#event-{{ event.id }}" data-search="{{ (event.title ~ ' ' ~ event.summary ~ ' ' ~ event.location ~ ' ' ~ event.source ~ ' ' ~ event.perks|join(' ') ~ ' ' ~ event.keywords|join(' '))|lower }}" data-source="{{ event.source|lower }}" data-fnb-types="{{ event.fnb_perks|map('lower')|join('|') if event.has_fnb else 'not-stated' }}"><time>{{ event.compact_time_label }}</time><span>{{ event.title }}</span></a>
                  {% endfor %}
                </div>
                {% endfor %}
              {% endfor %}
            </div>
          </section>
          {% endfor %}
        </div>
      </div>
      <div class="calendar-footer"><span>Scroll sideways on smaller screens. Click an event to jump to its full description.</span><strong id="active-month-count">{{ calendar_overview[0].event_count }} event{% if calendar_overview[0].event_count != 1 %}s{% endif %} this month</strong></div>
    </section>

    <div class="toolbar" aria-label="Event filters">
      <input class="search" id="search" type="search" placeholder="Search descriptions, titles, places or perks…" aria-label="Search events">
      <select class="select" id="source" aria-label="Filter by source">
        <option value="">All sources</option>
        {% for option in source_options %}<option value="{{ option.value }}">{{ option.label }}</option>{% endfor %}
      </select>
      <select class="select" id="fnb" aria-label="Filter by food and beverage">
        <option value="">All F&amp;B types</option>
        {% for fnb_type in fnb_types %}<option value="{{ fnb_type|lower }}">{{ fnb_type }}</option>{% endfor %}
        <option value="not-stated">Not stated</option>
      </select>
    </div>

    <div class="agenda-heading"><h2>Upcoming event details</h2><p>Descriptions are condensed only from organizer-provided event descriptions. No inferred summaries are generated.</p></div>
    <section id="events" aria-live="polite" aria-label="Upcoming event details">
      {% for month in calendar_months %}
      <section class="agenda-month" data-month="{{ month.month_key }}">
        <div class="month-heading"><h3>{{ month.month_label }}</h3><span>{{ month.event_count }} event{% if month.event_count != 1 %}s{% endif %}</span></div>
        {% for day in month.days %}
        <section class="calendar-day" data-date="{{ day.date_key }}" aria-label="{{ day.date_label }}">
          <div class="day-rail"><strong>{{ day.day_number }}</strong><span>{{ day.weekday }}</span></div>
          <div class="day-events">
            {% for event in day.events %}
            <article id="event-{{ event.id }}" class="event-card{% if event.has_fnb or 'Networking' in event.perks %} featured{% endif %}" data-search="{{ (event.title ~ ' ' ~ event.summary ~ ' ' ~ event.location ~ ' ' ~ event.source ~ ' ' ~ event.popularity_label ~ ' ' ~ event.perks|join(' ') ~ ' ' ~ event.keywords|join(' '))|lower }}" data-source="{{ event.source|lower }}" data-fnb-types="{{ event.fnb_perks|map('lower')|join('|') if event.has_fnb else 'not-stated' }}">
              <div class="event-main">
                <div class="topline"><span class="source">{{ event.source }}</span><span class="pill window">{{ event.day_type }}</span>{% if event.hot_pick %}<span class="pill hot">Hot pick</span>{% endif %}</div>
                <h4>{{ event.title }}</h4>
                {% if event.summary %}<p class="summary">{{ event.summary }}</p>{% else %}<p class="summary missing">{{ event.summary_note }}</p>{% endif %}
                <div class="tags">
                  {% for perk in event.perks %}<span class="tag perk">{{ perk }}</span>{% endfor %}
                  {% for keyword in event.keywords %}<span class="tag">{{ keyword }}</span>{% endfor %}
                </div>
              </div>
              <aside class="event-side">
                <div class="meta">
                  <span><b>When</b><br>{{ event.date_label }}<br>{{ event.time_label }}</span>
                  <span><b>Where</b><br>{{ event.location }}</span>
                </div>
                <div class="fnb-status{% if not event.has_fnb %} none{% endif %}"><span>Food &amp; beverage</span><strong>{{ event.fnb_label }}</strong></div>
                {% if event.popularity_label %}<div class="popularity"><span>Signup interest</span><strong>{{ event.popularity_label }}</strong></div>{% endif %}
                <a class="register" href="{{ event.url }}" target="_blank" rel="noopener noreferrer"><span>Registration &amp; details</span><span>↗</span></a>
              </aside>
            </article>
            {% endfor %}
          </div>
        </section>
        {% endfor %}
      </section>
      {% endfor %}
      <div class="empty" id="empty"{% if events %} hidden{% endif %}>
        <h2>No matches yet.</h2>
        <p>{% if events %}Try a broader search or reset the source and F&amp;B filters.{% else %}The latest run found no events that met the topic, location, date, and timing filters. Check back after the next Sunday refresh.{% endif %}</p>
      </div>
    </section>

    <details class="status-panel">
      <summary>Run health · generated {{ generated_at }}</summary>
      <div class="statuses">
        {% for status in statuses %}
        <div class="status"><b>{{ status.source }}</b><br><span class="state-{{ status.state }}">{{ status.state }}</span>{% if status.found %} · {{ status.found }} candidates{% endif %}</div>
        {% endfor %}
      </div>
      <p><small>Accepted {{ report.accepted }}. Rejections: {% for reason, count in report.rejected.items() %}{{ reason }}={{ count }}{% if not loop.last %}, {% endif %}{% else %}none{% endfor %}.</small></p>
    </details>
    <footer>Times shown in Singapore Time (SGT). F&amp;B and signup interest appear only when explicitly exposed by the source; missing data is left unstated.</footer>
  </main>
  <script>
    if (new URLSearchParams(window.location.search).has('presentation')) {
      document.body.classList.add('presentation-mode');
    }
    const search = document.querySelector('#search');
    const source = document.querySelector('#source');
    const fnb = document.querySelector('#fnb');
    const cards = [...document.querySelectorAll('.event-card')];
    const calendarEvents = [...document.querySelectorAll('.calendar-event')];
    const calendarCells = [...document.querySelectorAll('.month-cell')];
    const agendaDays = [...document.querySelectorAll('.calendar-day')];
    const agendaMonths = [...document.querySelectorAll('.agenda-month')];
    const monthPanels = [...document.querySelectorAll('.month-panel')];
    const count = document.querySelector('#visible-count');
    const empty = document.querySelector('#empty');
    const monthLabel = document.querySelector('#active-month-label');
    const monthCount = document.querySelector('#active-month-count');
    const previousMonth = document.querySelector('#previous-month');
    const nextMonth = document.querySelector('#next-month');
    let activeMonth = 0;

    function visibleCalendarEvents(panel) {
      return [...panel.querySelectorAll('.calendar-event')].filter(event => !event.hidden).length;
    }

    function showMonth(index) {
      activeMonth = Math.max(0, Math.min(index, monthPanels.length - 1));
      monthPanels.forEach((panel, panelIndex) => { panel.hidden = panelIndex !== activeMonth; });
      const panel = monthPanels[activeMonth];
      const visible = visibleCalendarEvents(panel);
      monthLabel.textContent = panel.dataset.monthLabel;
      monthCount.textContent = `${visible} event${visible === 1 ? '' : 's'} this month`;
      previousMonth.disabled = activeMonth === 0;
      nextMonth.disabled = activeMonth === monthPanels.length - 1;
    }

    function matchesFilters(element, query, selectedSource, selectedFnb) {
      return (!query || element.dataset.search.includes(query))
        && (!selectedSource || element.dataset.source === selectedSource)
        && (!selectedFnb || element.dataset.fnbTypes.split('|').includes(selectedFnb));
    }

    function filterCards() {
      const query = search.value.trim().toLowerCase();
      const selectedSource = source.value;
      const selectedFnb = fnb.value;
      let visible = 0;
      cards.forEach(card => {
        const show = matchesFilters(card, query, selectedSource, selectedFnb);
        card.hidden = !show;
        if (show) visible += 1;
      });
      calendarEvents.forEach(event => {
        event.hidden = !matchesFilters(event, query, selectedSource, selectedFnb);
      });
      calendarCells.forEach(cell => {
        const hasVisible = [...cell.querySelectorAll('.calendar-event')].some(event => !event.hidden);
        cell.classList.toggle('has-events', hasVisible);
      });
      agendaDays.forEach(day => {
        day.hidden = ![...day.querySelectorAll('.event-card')].some(card => !card.hidden);
      });
      agendaMonths.forEach(month => {
        month.hidden = ![...month.querySelectorAll('.calendar-day')].some(day => !day.hidden);
      });
      if (visible > 0 && visibleCalendarEvents(monthPanels[activeMonth]) === 0) {
        const nextVisibleMonth = monthPanels.findIndex(panel => visibleCalendarEvents(panel) > 0);
        if (nextVisibleMonth >= 0) activeMonth = nextVisibleMonth;
      }
      count.textContent = visible;
      empty.hidden = visible !== 0;
      showMonth(activeMonth);
    }

    previousMonth.addEventListener('click', () => showMonth(activeMonth - 1));
    nextMonth.addEventListener('click', () => showMonth(activeMonth + 1));
    search.addEventListener('input', filterCards);
    source.addEventListener('change', filterCards);
    fnb.addEventListener('change', filterCards);
    showMonth(0);
  </script>
</body>
</html>
